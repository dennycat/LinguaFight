<Window x:Class="LinguaFight.Windows.TimerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Налаштування таймера" Height="450" Width="800">

    <Grid Background="#1E1E1E">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">

            <TextBlock Text="Налаштування таймера"
                       Foreground="White"
                       FontSize="26"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <TextBlock Text="Години"
                       Foreground="White"
                       FontSize="18"
                       Margin="0 0 0 5"/>
            <TextBox x:Name="HoursBox"
                     Height="35"
                     Background="#2A2A2A"
                     Foreground="White"
                     BorderBrush="#3A8DFF"
                     BorderThickness="2"
                     Margin="0 0 0 15"/>

            <TextBlock Text="Хвилини"
                       Foreground="White"
                       FontSize="18"
                       Margin="0 0 0 5"/>
            <TextBox x:Name="MinutesBox"
                     Height="35"
                     Background="#2A2A2A"
                     Foreground="White"
                     BorderBrush="#3A8DFF"
                     BorderThickness="2"
                     Margin="0 0 0 15"/>

            <TextBlock Text="Секунди"
                       Foreground="White"
                       FontSize="18"
                       Margin="0 0 0 5"/>
            <TextBox x:Name="SecondsBox"
                     Height="35"
                     Background="#2A2A2A"
                     Foreground="White"
                     BorderBrush="#3A8DFF"
                     BorderThickness="2"
                     Margin="0 0 0 20"/>

            <Button Content="Встановити таймер"
                    Height="40"
                    Background="#3A8DFF"
                    Foreground="White"
                    Click="SetTimer_Click"/>

            <Button Content="Назад"
                    Height="40"
                    Background="#555"
                    Foreground="White"
                    Margin="0 10 0 0"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
