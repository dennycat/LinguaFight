<Window x:Class="LinguaFight.Windows.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LinguaFight — Вхід" Height="450" Width="800"
        Background="#1E1E1E">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

            <TextBlock Text="LinguaFight v1.1" 
                       Foreground="White" 
                       FontSize="26" 
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <!-- Логін (нікнейм або email) -->
            <TextBlock Text="Нікнейм або Email:" Foreground="White" Margin="0 0 0 5"/>
            <TextBox x:Name="LoginBox"
                     Height="35"
                     FontSize="18"
                     Margin="0 0 0 15"/>

            <!-- Пароль -->
            <TextBlock Text="Пароль:" Foreground="White" Margin="0 0 0 5"/>
            <PasswordBox x:Name="PasswordBox"
                         Height="35"
                         FontSize="18"
                         Margin="0 0 0 20"/>

            <!-- Кнопка входу -->
            <Button Content="Продовжити" 
                    Height="40" 
                    Background="#3A8DFF" 
                    Foreground="White"
                    Click="ContinueButton_Click"/>

            <!-- Кнопка реєстрації -->
            <Button Content="Реєстрація"
                    Height="35"
                    Background="#555"
                    Foreground="White"
                    Margin="0 10 0 0"
                    Click="RegisterButton_Click"/>
        </StackPanel>
    </Grid>

</Window>
