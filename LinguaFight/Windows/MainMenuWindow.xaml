<Window x:Class="LinguaFight.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LinguaFight"
        mc:Ignorable="d"
        Title="MainMenuWindow" Height="450" Width="800">

    <Grid Background="#1E1E1E">

        <!-- Вітання та монети -->
        <TextBlock x:Name="WelcomeText"
                   Text="Вітаю!"
                   Foreground="White"
                   FontSize="22"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Margin="10 10 0 0"/>

        <TextBlock x:Name="CoinsDisplay"
                   Text="Монети: 0"
                   Foreground="White"
                   FontSize="22"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0 10 10 0"/>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

            <TextBlock Text="Головне меню"
                       Foreground="White"
                       FontSize="26"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <Button Content="Почати тренування"
                    Height="40"
                    Margin="0 0 0 10"
                    Background="#3A8DFF"
                    Foreground="White"
                    Click="StartTraining_Click"/>

            <!-- 🔥 НОВА КНОПКА БІЙ -->
            <Button Content="Бій"
                    Height="40"
                    Margin="0 0 0 10"
                    Background="#3A8DFF"
                    Foreground="White"
                    Click="Battle_Click"/>

            <Button Content="Словники"
                    Height="40"
                    Margin="0 0 0 10"
                    Background="#3A8DFF"
                    Foreground="White"
                    Click="SelectDictionary_Click"/>

            <Button Content="Досягнення"
                    Height="40"
                    Margin="0 0 0 10"
                    Background="#3A8DFF"
                    Foreground="White"
                    Click="Achievements_Click"/>

            <Button Content="Налаштування"
                    Height="40"
                    Margin="0 0 0 10"
                    Background="#3A8DFF"
                    Foreground="White"
                    Click="Settings_Click"/>

            <Button Content="Вихід"
                    Height="40"
                    Background="#FF4A4A"
                    Foreground="White"
                    Click="Exit_Click"/>
        </StackPanel>
    </Grid>

</Window>
