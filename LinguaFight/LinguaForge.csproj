<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <!-- ❗ ВАЖЛИВО: Remove видаляємо -->
  <!-- (ці блоки забороняли WPF бачити картинки) -->

  <ItemGroup>
    <None Remove="Resources\Dictionaries\animals.json" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Resources\Dictionaries\unity_csharp.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Include="Resources\Dictionaries\Animals\Animals.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Logic\" />
    <Folder Include="Resources\Dictionaries\Animals\Animations\" />
    <Folder Include="Resources\Dictionaries\Animals\Sounds\" />
    <Folder Include="Resources\Icons\" />
    <Folder Include="Resources\Sounds\" />
  </ItemGroup>

  <!-- ❗ Картинки тепер копіюються автоматично -->
  <ItemGroup>
    <None Include="Resources\Dictionaries\Animals\Images\**\*.png">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <None Update="Resources\Sounds\coin.wav">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="Resources\Sounds\training_start.wav">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
