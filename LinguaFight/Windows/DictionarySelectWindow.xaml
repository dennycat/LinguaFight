<Window x:Class="LinguaFight.Windows.DictionarySelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LinguaFight.Windows"
        mc:Ignorable="d"
        Title="DictionarySelectWindow" Height="450" Width="800">
    <Grid Background="#1E1E1E">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">

            <TextBlock Text="Вибір словника"
                   Foreground="White"
                   FontSize="26"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 20"/>
            <TextBlock x:Name="CurrentDictionaryText"
                   FontSize="18"
                   Margin="0 0 0 10"
                   Text="(не вибрано)" />

            <ListBox x:Name="DictionaryList"
                 Height="200"
                 Background="#2A2A2A"
                 Foreground="White"
                 BorderBrush="#3A8DFF"
                 BorderThickness="2"
                 Margin="0 0 0 20"/>

            <Button Content="Обрати"
                Height="40"
                Background="#3A8DFF"
                Foreground="White"
                Click="Select_Click"/>

            <Button Content="Назад"
                Height="40"
                Background="#555"
                Foreground="White"
                Margin="0 10 0 0"
                Click="Back_Click"/>
        </StackPanel>
    </Grid>

</Window>
