<Window x:Class="LinguaFight.Windows.AchievementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Досягнення" Height="450" Width="800"
        Background="#1E1E1E">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">

            <TextBlock Text="Досягнення"
                       Foreground="White"
                       FontSize="26"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <TextBlock Text="Монети:"
                       Foreground="White"
                       FontSize="20"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="CoinsText"
                       Foreground="#3A8DFF"
                       FontSize="32"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0 10 0 20"/>

            <Button Content="Назад"
                    Height="40"
                    Background="#555"
                    Foreground="White"
                    Click="Back_Click"/>
        </StackPanel>
    </Grid>

</Window>
