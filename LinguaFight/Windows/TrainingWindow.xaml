<Window x:Class="LinguaFight.Windows.TrainingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LinguaFight.Windows"
        mc:Ignorable="d"
        Title="TrainingWindow" Height="450" Width="800"
        KeyDown="Window_KeyDown">

    <Grid Background="#1E1E1E">

        <!-- Монети у правому верхньому кутку -->
        <TextBlock x:Name="CoinsDisplay"
                   Text="Монети: 0"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0 10 10 0"
                   Padding="5"
                   TextWrapping="NoWrap"
                   MinWidth="150"
                   RenderTransformOrigin="0.5,0.5">
            <TextBlock.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </TextBlock.RenderTransform>
        </TextBlock>

        <!-- Анімація +N -->
        <TextBlock x:Name="CoinsGainText"
                   Text=""
                   Foreground="#3AFF5A"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0 40 10 0"
                   Opacity="0"/>

        <!-- Основний контент -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="350">

            <TextBlock x:Name="WordText"
                       Text="Слово"
                       Foreground="White"
                       FontSize="26"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <TextBox x:Name="AnswerBox"
                     Height="35"
                     FontSize="18"
                     Margin="0 0 0 20"/>

            <Button Content="Відповісти"
                    Height="40"
                    Background="#3A8DFF"
                    Foreground="White"
                    Click="Answer_Click"
                    IsDefault="True"/>

            <TextBlock x:Name="ResultText"
                       Text=""
                       Foreground="White"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0 20 0 0"
                       Width="331"/>
        </StackPanel>

    </Grid>

</Window>
