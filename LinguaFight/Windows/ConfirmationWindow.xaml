<Window x:Class="LinguaFight.Windows.ConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Підтвердження пошти" Height="250" Width="500"
        Background="#1E1E1E">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">

            <TextBlock Text="Введіть код підтвердження"
                       Foreground="White"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <TextBox x:Name="CodeBox"
                     Height="35"
                     FontSize="18"
                     Margin="0 0 0 20"/>

            <Button Content="Підтвердити"
                    Height="40"
                    Background="#3A8DFF"
                    Foreground="White"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>

</Window>
