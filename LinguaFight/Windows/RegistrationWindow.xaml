<Window x:Class="LinguaFight.Windows.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Реєстрація" Height="450" Width="800"
        Background="#1E1E1E">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">

            <!-- Заголовок -->
            <TextBlock Text="Реєстрація"
                       Foreground="White"
                       FontSize="28"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 20"/>

            <!-- Нікнейм -->
            <TextBlock Text="Нікнейм"
                       Foreground="White"
                       FontSize="16"
                       Margin="0 0 0 5"/>
            <TextBox x:Name="NicknameBox"
                     Height="35"
                     FontSize="18"
                     Margin="0 0 0 10"/>

            <!-- Електронна пошта -->
            <TextBlock Text="Електронна пошта"
                       Foreground="White"
                       FontSize="16"
                       Margin="0 0 0 5"/>
            <TextBox x:Name="EmailBox"
                     Height="35"
                     FontSize="18"
                     Margin="0 0 0 10"/>

            <!-- Пароль -->
            <TextBlock Text="Пароль"
                       Foreground="White"
                       FontSize="16"
                       Margin="0 0 0 5"/>
            <PasswordBox x:Name="PasswordBox"
                         Height="35"
                         FontSize="18"
                         Margin="0 0 0 10"/>

            <!-- Підтвердження паролю -->
            <TextBlock Text="Підтвердження паролю"
                       Foreground="White"
                       FontSize="16"
                       Margin="0 0 0 5"/>
            <PasswordBox x:Name="ConfirmPasswordBox"
                         Height="35"
                         FontSize="18"
                         Margin="0 0 0 20"/>

            <!-- Кнопка -->
            <Button Content="Продовжити"
                    Height="40"
                    Background="#3A8DFF"
                    Foreground="White"
                    Click="Continue_Click"/>
        </StackPanel>
    </Grid>

</Window>
